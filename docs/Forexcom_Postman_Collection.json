{
  "info": {
    "name": "MarketApp - Forex.com / StoneX",
    "description": "Collection para probar los endpoints Forex.com/StoneX desde Postman.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000/api/forexcom",
      "type": "string"
    },
    {
      "key": "username",
      "value": "",
      "type": "string"
    },
    {
      "key": "password",
      "value": "",
      "type": "string"
    },
    {
      "key": "appKey",
      "value": "",
      "type": "string"
    },
    {
      "key": "isDemo",
      "value": "false",
      "type": "string"
    },
    {
      "key": "sessionToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "GET /config",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/config",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "config"
              ]
            }
          },
          "response": []
        },
        {
          "name": "POST /login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "if (json.sessionToken) {",
                  "  pm.collectionVariables.set(\"sessionToken\", json.sessionToken);",
                  "}",
                  "if (json.username) {",
                  "  pm.collectionVariables.set(\"username\", json.username);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\",\n  \"appKey\": \"{{appKey}}\",\n  \"isDemo\": \"{{isDemo}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET /auth/status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-forex-session",
                "value": "{{sessionToken}}"
              },
              {
                "key": "x-forex-username",
                "value": "{{username}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "status"
              ]
            }
          },
          "response": []
        },
        {
          "name": "POST /logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-forex-session",
                "value": "{{sessionToken}}"
              },
              {
                "key": "x-forex-username",
                "value": "{{username}}"
              }
            ],
            "url": {
